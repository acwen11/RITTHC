Cell["Derivative matrix", "Text"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"deriv", "[", "n_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "d", "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"d", "=", 
       RowBox[{"Outer", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"#1", "\[NotEqual]", "#2"}], ",", 
            FractionBox[
             RowBox[{"LegendreP", "[", 
              RowBox[{"n", ",", "#1"}], "]"}], 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"#1", "-", "#2"}], ")"}], 
              RowBox[{"LegendreP", "[", 
               RowBox[{"n", ",", "#2"}], "]"}]}]], ",", "0"}], "]"}], "&"}], 
         ",", 
         RowBox[{"abscissas", "[", "n", "]"}], ",", 
         RowBox[{"abscissas", "[", "n", "]"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"d", "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", "1"}], "]"}], "]"}], "=", 
       RowBox[{
        RowBox[{"-", "n"}], 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"n", "+", "1"}], ")"}], "/", "4"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"d", "[", 
        RowBox[{"[", 
         RowBox[{
          RowBox[{"-", "1"}], ",", 
          RowBox[{"-", "1"}]}], "]"}], "]"}], "=", 
       RowBox[{"-", 
        RowBox[{"d", "[", 
         RowBox[{"[", 
          RowBox[{"1", ",", "1"}], "]"}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", "d"}]}], "\[IndentingNewLine]", "]"}]}], 
  ";"}]], "Input"],


Cell["Interpolation weights", "Text"],

Cell[BoxData[
 RowBox[{
  RowBox[{"iweights", "[", "n_", "]"}], ":=", 
  RowBox[{"1", "/", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Times", "@@", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"abscissas", "[", "n", "]"}], "[", 
         RowBox[{"[", "i", "]"}], "]"}], "-", 
        RowBox[{"Drop", "[", 
         RowBox[{
          RowBox[{"abscissas", "[", "n", "]"}], ",", 
          RowBox[{"{", "i", "}"}]}], "]"}]}], ")"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", 
       RowBox[{"n", "+", "1"}]}], "}"}]}], "]"}]}]}]], "Input"],


Cell["Prolongation", "Text"],

Cell[BoxData[
 RowBox[{
  RowBox[{"xamr", "[", "n_", "]"}], ":=", 
  RowBox[{"Join", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"abscissas", "[", "n", "]"}], "-", "1"}], ")"}], "/", "2"}], 
    ",", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"abscissas", "[", "n", "]"}], "+", "1"}], ")"}], "/", "2"}]}], 
   "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{
  RowBox[{"vander", "[", "x_", "]"}], ":=", 
  RowBox[{
   RowBox[{"Quiet", "[", 
    RowBox[{
     RowBox[{"Outer", "[", 
      RowBox[{"Power", ",", "x", ",", 
       RowBox[{"Range", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "x", "]"}], "-", "1"}], ",", "0", ",", 
         RowBox[{"-", "1"}]}], "]"}]}], "]"}], ",", 
     RowBox[{"Power", "::", "indet"}]}], "]"}], "/.", 
   RowBox[{"Indeterminate", "\[Rule]", "1", " ", 
    RowBox[{"(*", " ", 
     RowBox[{"Avoid", " ", 
      RowBox[{"0", "^", "0"}], " ", "problems"}], " ", "*)"}]}]}]}]], "Input"],

Cell[BoxData[
 RowBox[{
  RowBox[{"prolongation", "[", "n_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "x", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"Transpose", "[", 
     RowBox[{
      RowBox[{
       SuperscriptBox["x", 
        RowBox[{"Range", "[", 
         RowBox[{"n", ",", "0", ",", 
          RowBox[{"-", "1"}]}], "]"}]], ".", 
       RowBox[{"Inverse", "[", 
        RowBox[{"vander", "[", 
         RowBox[{"abscissas", "[", "n", "]"}], "]"}], "]"}]}], "/.", 
      RowBox[{"x", "\[Rule]", 
       RowBox[{"xamr", "[", "n", "]"}]}]}], "]"}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input"],


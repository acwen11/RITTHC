Notebook[{
Cell["\<\
Compute the various coefficients requires for Guass-Legendre-Lobatto \
quadrature on [-1, 1]. We can either do it ourselves or use some hidden \
NIntegrate functions.\
\>", "Text"],

Cell[BoxData[
 RowBox[{
  RowBox[{"n", "=", "5"}], ";"}]], "Input"],

Cell["Abscissas", "Text"],

Cell[BoxData[
 RowBox[{
  RowBox[{"abscissas", "[", "n_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "x", "}"}], ",", 
    RowBox[{"Sort", "[", 
     RowBox[{"x", "/.", 
      RowBox[{"N", "[", 
       RowBox[{
        RowBox[{"NSolve", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"1", "-", 
              SuperscriptBox["x", "2"]}], ")"}], 
            RowBox[{"D", "[", 
             RowBox[{
              RowBox[{"LegendreP", "[", 
               RowBox[{"n", ",", "x"}], "]"}], ",", "x"}], "]"}]}], 
           "\[Equal]", "0"}], ",", "x", ",", "Reals", ",", 
          RowBox[{"WorkingPrecision", "\[Rule]", "32"}]}], "]"}], ",", "32"}],
        "]"}]}], "]"}]}], "]"}]}]], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"N", "[", 
  RowBox[{
   RowBox[{"abscissas", "[", "n", "]"}], ",", "5"}], "]"}]], "Input"],


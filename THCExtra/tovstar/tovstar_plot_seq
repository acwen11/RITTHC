#!/usr/bin/env python
# -*- coding: utf-8 -*-
import os
from optparse import OptionParser
from numpy import *


def page_setup():
  fig_width = 6.0
  fig_height = fig_width / 1.618
  params = {
    'figure.figsize' : [fig_width,fig_height],
    #'figure.subplot.left' : 0.1,
    #'figure.subplot.right' : 0.95,
    #'figure.subplot.top' : 0.9,
    'figure.subplot.bottom' : 0.15,
    'lines.markersize': 6,
    'axes.labelsize': 11,
    #'text.usetex':True,
    'text.fontsize': 11,
    'legend.fontsize': 10,
    'xtick.labelsize': 10,
    'ytick.labelsize': 10,
    'axes.formatter.limits': [-2,3],
    'savefig.dpi': 72,
    'lines.antialiased': True
  }
  rcParams.update(params)
  clf()
#

def loadtab(d, cols):
  a  = loadtxt(d, usecols=cols, unpack=True)
  if len(a.shape)==1:
    return [array([x]) for x in a]
  #
  return a
#

def get_seq(path):
  rmd, mg, r, eb  = loadtab(path, (0,1,2,3))
  mb = mg + eb
  return os.path.basename(path), rmd, mb, mg, r
#

def plot_m_vs_d(seqs, pnts, name):
  page_setup()
  gca().set_xscale("log", nonposx='clip')
  msol = 1.98892e+30
  clrs=['b','r','k','g']
  for i,(sn,rmd,mb,mg,r) in enumerate(seqs):
    plot(rmd, mg/msol, '-', color=clrs[i], label=r'$M_g$ '+sn)
    plot(rmd, mb/msol, ':', color=clrs[i])
  #
  for i,(sn,rmd,mb,mg,r) in enumerate(pnts):
    plot(rmd, mg/msol, 'o', color=clrs[i], label=sn)
    plot(rmd, mb/msol, 'x', color=clrs[i])
  #
  axhline(y=1.97, ls='--', color='grey', label='J1614-2230')
  nucl_dens = 2e17
  axvline(x=nucl_dens, ls=':', color='magenta')
  legend(loc='best')
  ylabel(r'$M / M_\odot$')
  xlabel(r'$\rho_c / (\mathrm{kg}\,\mathrm{m}^{-3})$')
  savefig(name)
#

def plot_m_vs_r(seqs, points, name):
  km    = 1e3
  page_setup()
  minrs = min([s[4].min() for s in seqs])
  maxrs = max([s[4].max() for s in seqs])
  if (minrs<maxrs*0.05):
    gca().set_xscale("log", nonposx='clip')
  msol = 1.98892e+30
  clrs=['b','r','k','g']
  for i,(sn,rmd,mb,mg,r) in enumerate(seqs):
    plot(r/km, mg/msol, ls='-',color=clrs[i], label=r'$M_g$ '+sn)
    plot(r/km, mb/msol, ls=':',color=clrs[i])
  #
  for i,(sn,rmd,mb,mg,r) in enumerate(pnts):
    plot(r/km, mg/msol, 'o', color=clrs[i], label=sn)
    plot(r/km, mb/msol, 'x', color=clrs[i])
  #
  axhline(y=1.97, ls='--', color='grey', label='J1614-2230')
  legend(loc='best')
  ylabel(r'$M / M_\odot$')
  xlabel(r'$R / \mathrm{km}$')
  savefig(name)
#

m_vs_r = 'mass_vs_radius'
m_vs_d = 'mass_vs_dens'
usage = "usage: %prog [--format <fmt>] [<sequences>]"
desc="""Create mass versus radius and mass versus density plots
for a star sequence, stored in the format generated by tovstars.
By default, plot the file "sequence.dat". If <sequences> are
given as argument, plot them all on top of each other. Sequences
with only one data point are plotted as a point. This is intended 
to add points for single star(s) as saved by tovstar under the 
name "point.dat". Format can be anything matplotlib supports,
including pdf,eps,png. The plots created are named "%s" and "%s".
""" % (m_vs_r, m_vs_d)

parser = OptionParser(usage, description=desc)
parser.add_option('--format', dest='format',default='Pdf' , help="Image format of plots")

(opt, args) = parser.parse_args()

import matplotlib
matplotlib.use(opt.format)
from pylab import *

try:
  if (len(args)==0):
    args = ['sequence.dat']
  #

  seqs = [get_seq(p) for p in args]
  pnts = [s for s in seqs if len(s[1])==1]
  seqs = [s for s in seqs if len(s[1])>1]

  plot_m_vs_d(seqs, pnts, m_vs_d)
  plot_m_vs_r(seqs, pnts, m_vs_r)
except Exception,inst:
  print '..failed (',inst,').'
#


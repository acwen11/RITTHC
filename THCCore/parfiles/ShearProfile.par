ActiveThorns = "
ADMBase
ADMCoupling
ADMMacros
Boundary
Carpet
CarpetIOASCII
CarpetIOBasic
CarpetIOScalar
CarpetLib
CarpetReduce
CarpetSlab
CartGrid3d
CoordBase
EOS_Thermal
EOS_Thermal_Idealgas
HydroBase
HRSCCore
InitBase
IOUtil
LoopControl
MoL
NanChecker
Periodic
Slab
StaticConformal
SymBase
THC_Core
THC_InitialData
THC_SubGrid
THC_Tracer
Time
TmunuBase
"

#############################################################
# Grid
#############################################################

CoordBase::domainsize                   = minmax

CoordBase::xmin                         = -0.5
CoordBase::ymin                         = -0.5
CoordBase::zmin                         = -0.5

CoordBase::xmax                         = 0.5
CoordBase::ymax                         = 0.5
CoordBase::zmax                         = 0.5

CoordBase::spacing                      = "numcells"
CoordBase::ncells_x                     = 40
CoordBase::ncells_y                     = 1
CoordBase::ncells_z                     = 1

CoordBase::boundary_size_x_lower        = 3
CoordBase::boundary_size_y_lower        = 3
CoordBase::boundary_size_z_lower        = 3
CoordBase::boundary_shiftout_x_lower    = 1
CoordBase::boundary_shiftout_y_lower    = 1
CoordBase::boundary_shiftout_z_lower    = 1

CoordBase::boundary_size_x_upper        = 3
CoordBase::boundary_size_y_upper        = 3
CoordBase::boundary_size_z_upper        = 3
CoordBase::boundary_shiftout_x_upper    = 0
CoordBase::boundary_shiftout_y_upper    = 1
CoordBase::boundary_shiftout_z_upper    = 1

CartGrid3D::type                        = "coordbase"
CartGrid3D::domain                      = "full"
CartGrid3D::avoid_origin                = "no"

#############################################################
# Carpet
#############################################################

Carpet::ghost_size                      = 3
Carpet::domain_from_coordbase           = "yes"
Carpet::max_refinement_levels           = 1
Carpet::init_each_timelevel             = "no"
Carpet::num_integrator_substeps         = 3

#############################################################
# Time integration
#############################################################

Cactus::terminate                     = "time"
Cactus::cctk_final_time               = 10.0
Cactus::cctk_itlast	                  = 2

Time::timestep_method                 = "courant_static"
Time::dtfac                           = 0.15
Time::courant_fac                     = 0.15

MethodOfLines::ode_method             = "RK3"
MethodOfLines::MoL_Intermediate_Steps = 3
MethodOfLines::MoL_Num_Scratch_Levels = 1
MethodOfLines::MoL_NaN_Check          = "yes"
MethodOfLines::verbose                = "register"

#############################################################
# Templated Hydrodynamics code
#############################################################

HydroBase::evolution_method           = "THCode"
HydroBase::timelevels                 = 3

HRSCCore::scheme                      = "FD"
HRSCCore::pplim                       = "no"
HRSCCore::reconstruction              = "MP5"
HRSCCore::flux_split                  = "RF"
HRSCCore::system_split                = "characteristics"

TmunuBase::support_old_CalcTmunu_mechanism = "no"

THC_SubGrid::model                    = "viscous"
THC_SubGrid::viscosity                = "const"
THC_SubGrid::lmix                     = 0.01

EOS_Thermal::evol_eos_name            = "IdealGas"
EOS_Thermal_IdealGas::index_n         = 3.0

THC_InitialData::id_type              = "shear"
THC_InitialData::shear_velocity       = 0.0
THC_InitialData::shear_amplitude      = 0.01

THC_Core::physics                     = "SRHD"

THC_Core::eos_type                    = "ideal"
Periodic::periodic                    = "yes"

THC_Core::c2a_kill_on_failure         = "yes"
THC_Core::c2a_zmax                    = 100
THC_Core::c2a_rho_strict              = 0

THC_Core::eig_min_rho                 = 0
THC_Core::verbose                     = "no"

EOS_Thermal_IdealGas::rho_max         = 1e16
EOS_Thermal_IdealGas::eps_max         = 1e16

#############################################################
# Output
#############################################################

IO::out_dir                   = $parfile
IO::out_fileinfo              = "all"

CarpetIOBasic::outInfo_every  = 20
CarpetIOBasic::outInfo_vars   = "HydroBase::w_lorentz HydroBase::vel[1]"

CarpetIOScalar::outScalar_every      = 20
CarpetIOScalar::outScalar_reductions = "
minimum maximum norm_inf norm1 norm2
"
CarpetIOScalar::outScalar_vars       = "
HydroBase::eps
HydroBase::press
HydroBase::rho
HydroBase::vel
HydroBase::w_lorentz
THC_Core::dens
THC_Core::scon
THC_Core::tau
THC_SubGrid::turb_stress
THC_SubGrid::nu_turb
"

CarpetIOASCII::out1D_every          = 20
CarpetIOASCII::out1D_x              = "yes"
CarpetIOASCII::out1D_y              = "yes"
CarpetIOASCII::out1D_z              = "yes"
CarpetIOASCII::out1D_vars           = "
HydroBase::eps
HydroBase::press
HydroBase::rho
HydroBase::vel
HydroBase::w_lorentz
THC_Core::dens
THC_Core::scon
THC_Core::tau
THC_SubGrid::turb_stress
THC_SubGrid::nu_turb
"

CarpetIOASCII::out_precision  = 19
CarpetIOASCII::out3D_ghosts   = "yes"

# vim: set ft=sh tabstop=20 noexpandtab :

# Parameter definitions for thorn THC_Refluxing

SHARES: HRSCCore
USES BOOLEAN refluxing

SHARES: Refluxing
USES CCTK_INT refluxing_nvars

SHARES: THC_Core
USES KEYWORD eos_type

SHARES: THC_Tracer
USES INT ntracers

PRIVATE:

CCTK_INT nvars "Number of variables to be refluxed" ACCUMULATOR-BASE=Refluxing::refluxing_nvars
{
  4:10 :: "Number of variables which should be refluxed"
} 5
